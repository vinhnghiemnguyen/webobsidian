# ============================================================
# WebObsidian — copy to .env and edit, then `docker compose up -d --build`
#   cp .env.example .env
# .env is git-ignored, so your settings survive `git pull` / redeploys.
# ============================================================

# --- Docker deploy (docker compose) -------------------------
# Host path to your vault, bind-mounted to /vault inside the container.
# Absolute path, or relative to this compose file. The directory MUST exist.
# Defaults to the bundled ./sample-vault so the stack boots out of the box.
VAULT_HOST_PATH=./sample-vault

# Where to publish the web UI. Set HTTP_BIND=127.0.0.1 to expose only to
# localhost (e.g. behind an nginx/Caddy reverse proxy with TLS).
HTTP_BIND=0.0.0.0
HTTP_PORT=8787

# Proxy trust. Default "true" (trust the immediate hop) so X-Forwarded-Proto-based
# HTTPS cookie detection works behind a TLS-terminating reverse proxy out of the
# box. This is NOT a rate-limit risk: the login limiter keys on the real TCP socket
# address, not X-Forwarded-For, so it can't be bypassed by spoofing that header.
# Accepts "true"/hop count/subnet list (e.g. "loopback, 10.0.0.0/8"). Set "false"
# only for an instance exposed directly to clients with no reverse proxy.
TRUST_PROXY=true

# Initial master password. Leave empty to set it on first-run via the UI.
WEBOBSIDIAN_PASSWORD=

# File-watch mode:
#   auto    (default) native inotify, auto-falls back to polling if the host's
#           inotify watch limit is exceeded by a large vault.
#   polling force polling (no inotify; works anywhere, higher CPU).
# For large vaults, prefer raising the host limit over polling:
#   sudo sysctl -w fs.inotify.max_user_watches=524288
WEBOBSIDIAN_WATCH=auto

# --- Bare-metal only (npm run start, without docker) --------
# The container sets these itself; uncomment only when running outside docker.
# PORT=8787
# HOST=0.0.0.0
# VAULT_PATH=./sample-vault
# DATA_DIR=./data
# ALLOWED_ROOTS=
# NODE_ENV=production
